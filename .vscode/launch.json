{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug charges.test.ts",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "tests/charges.test.ts", "--no-file-parallelism"],
      "cwd": "${workspaceFolder}/tests/qa-test",
      "console": "integratedTerminal",
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug current test file (vitest)",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${fileBasename}", "--no-file-parallelism"],
      "cwd": "${workspaceFolder}/tests/qa-test",
      "console": "integratedTerminal",
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
